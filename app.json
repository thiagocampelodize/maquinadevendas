{
  "expo": {
    "name": "Máquina de Vendas",
    "slug": "maquina-de-vendas",
    "scheme": "maquina-de-vendas",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/logo-app.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo-app.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maquinadevendas.maquinadevendas",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "predictiveBackGestureEnabled": true,
      "package": "com.maquinadevendas.maquinadevendas"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "maquina-de-vendas"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3c24ab4-cc8a-4ccc-a3d8-cf9e21ed3972"
      }
    },
    "owner": "maquina-de-vendas"
  }
}
